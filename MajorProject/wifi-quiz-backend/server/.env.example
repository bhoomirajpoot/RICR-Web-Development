# ─────────────────────────────────────────────
# QuizNet Backend – Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/quiznet
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/quiznet

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Quiz Configuration
QUIZ_QUESTION_COUNT=10
QUIZ_PASS_PERCENTAGE=70
QUIZ_MAX_ATTEMPTS=3
QUIZ_TIMER_SECONDS=30

# CORS – comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
